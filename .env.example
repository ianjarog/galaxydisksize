# Example environment configuration. Copy to `.env` and fill in real values.
#   cp .env.example .env
# `.env` is git-ignored and must never be committed.
#
# These variables are needed ONLY for the optional provenance utility
# scripts/export_amiga_optical_diameters.py, which queries the internal IAA
# AMIGA database. The reproducible workflow does not need them — it runs from the
# committed CSVs. Most users can ignore this file entirely.

# --- AMIGA / CIG optical-diameter database (internal IAA service) ---
AMIGA_DB_HOST=amiga-db.iaa.es
AMIGA_DB_USER=amiga
AMIGA_DB_PASSWORD=
AMIGA_DB_PORT=
# Optional: override the output CSV path (defaults to data/amiga_full_catalogue_logd25.csv)
# AMIGA_DB_OUTPUT=data/amiga_full_catalogue_logd25.csv

# --- Optional workflow path / font overrides (see README "Configuration") ---
# GALAXYDISKSIZE_EXTERNAL=/path/to/large/external/data
# GALAXYDISKSIZE_FONT_DIR=/usr/share/fonts/tex-gyre
# GALAXYDISKSIZE_NO_MASKS=1
